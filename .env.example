# Coding-only models.
# These are the only two models needed for your coding workflow:
# - qwen2.5-coder:7b        -> Cline chat / coding agent
# - qwen2.5-coder:1.5b-base -> Continue tab autocomplete (FIM)
#
# You are pulling these manually with:
#   docker exec -it ollama ollama pull qwen2.5-coder:7b
#   docker exec -it ollama ollama pull qwen2.5-coder:1.5b-base
CHAT_MODELS=qwen2.5-coder:7b
AUTOCOMPLETE_MODELS=qwen2.5-coder:1.5b-base

# Extra reasoning models (optional)
# REASONING_MODELS=deepseek-r1:14b
REASONING_MODELS=

EMBED_MODEL=nomic-embed-text
COLLECTION_NAME=codebase
SCAN_INTERVAL=60

HYBRID_ENABLED=true
RERANK_ENABLED=true
RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
SPARSE_MODEL=Qdrant/bm25
