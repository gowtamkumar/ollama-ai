{
  "mcpServers": {
    "local-codebase-rag": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--network",
        "ollama-ai_ai-net",
        "-e",
        "RAG_API_URL=http://ai-rag-api:8011",
        "ollama-ai-mcp-rag:latest"
      ],
      "disabled": false,
      "autoApprove": ["search_codebase", "get_context"]
    }
  }
}
